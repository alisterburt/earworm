# Cloudflare R2 credentials for `earworm sync` (copy to .env, which is gitignored).
# Account ID: Cloudflare dashboard -> R2 (shown in the sidebar / bucket settings).
# Keys: R2 -> Manage R2 API Tokens -> Create API Token (Object Read & Write).
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
