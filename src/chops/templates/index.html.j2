<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>{{ title }} — chops</title>
<style>
  :root {
    --bg: #15171c; --panel: #1c1f26; --panel2: #21252e; --line: #2c313c;
    --text: #e7eaf0; --muted: #8b93a3; --accent: #5b9dff; --beat: #3a414f;
    --downbeat: #5c6479; --playhead: #ff5d5d; --master: #5b9dff;
    --whitekey: #2a2f3a; --blackkey: #1a1d24;
  }
  * { box-sizing: border-box; }
  html, body { margin: 0; height: 100%; }
  body {
    background: var(--bg); color: var(--text); font: 13px/1.4 -apple-system,
    BlinkMacSystemFont, "Segoe UI", system-ui, sans-serif; overflow: hidden;
    display: flex; flex-direction: column;
  }
  header {
    display: flex; align-items: center; gap: 16px; padding: 10px 16px; flex: none;
    background: var(--panel); border-bottom: 1px solid var(--line);
  }
  header h1 { font-size: 15px; margin: 0; font-weight: 600; }
  .meta { display: flex; gap: 16px; color: var(--muted); }
  .meta b { color: var(--text); font-weight: 600; }
  .spacer { flex: 1; }
  button, select {
    background: var(--panel2); color: var(--text); border: 1px solid var(--line);
    border-radius: 6px; padding: 6px 10px; cursor: pointer; font-size: 13px;
  }
  button:hover, select:hover { border-color: var(--accent); }
  button.play { min-width: 84px; font-weight: 600; }
  button.toggle.on { background: var(--accent); color: #0b1220; border-color: var(--accent); }
  .ctlgroup { display: flex; align-items: center; gap: 8px; color: var(--muted); }
  input[type=range] { accent-color: var(--accent); }

  #app { display: grid; grid-template-columns: 188px 1fr; flex: 1; min-height: 0; }
  #labels { background: var(--panel); border-right: 1px solid var(--line); overflow: hidden; }
  #scroll { overflow-x: auto; overflow-y: auto; position: relative; }
  #content { position: relative; height: 100%; }

  .lane-label, .lane { border-bottom: 1px solid var(--line); position: relative; }
  .lane-label {
    display: flex; align-items: center; gap: 8px; padding: 0 12px;
    color: var(--muted); font-weight: 600; cursor: pointer;
  }
  .lane-label.selectable:hover { background: #232834; }
  .lane-label.selected { box-shadow: inset 3px 0 0 var(--accent); }
  .lane-label .dot { width: 9px; height: 9px; border-radius: 50%; flex: none; }
  .lane-label .name { color: var(--text); text-transform: capitalize; }
  .lane-label .ctl { margin-left: auto; display: flex; gap: 4px; }
  .lane-label button.mini { padding: 2px 7px; font-size: 11px; border-radius: 4px; font-weight: 600; }
  button.mini.on { background: var(--accent); color: #0b1220; border-color: var(--accent); }
  button.mini.solo.on { background: #ffd166; color: #1a1500; border-color: #ffd166; }
  .lane canvas { display: block; position: absolute; inset: 0; }

  .disc { user-select: none; color: var(--text); background: var(--panel2); }
  .disc:hover { color: var(--accent); }
  .disc .arrow { display: inline-block; width: 12px; transition: transform .12s; }
  .disc.open .arrow { transform: rotate(90deg); }
  .disc-lane { background: var(--panel2); }
  .hidden { display: none !important; }

  #chordlane { position: relative; }
  .chord {
    position: absolute; top: 4px; bottom: 4px; border-radius: 4px;
    background: rgba(91,157,255,.16); border: 1px solid rgba(91,157,255,.4);
    color: #cfe0ff; font-size: 11px; font-weight: 600; padding: 2px 5px;
    overflow: hidden; white-space: nowrap; display: flex; align-items: center;
  }
  .chord.nc { background: rgba(120,128,144,.10); border-color: rgba(120,128,144,.3); color: var(--muted); }
  #lyriclane { position: relative; }
  .lyric-line {
    position: absolute; white-space: nowrap; height: 15px; line-height: 15px;
    font-size: 11px; color: #cdd3df;
  }
  .lyric-line.row0 { top: 3px; } .lyric-line.row1 { top: 19px; }
  .lyric-word { transition: color .08s ease; }
  .lyric-word.active { color: var(--accent); font-weight: 700; }
  .lyric-word.sung { color: #6f7787; }
  #playhead, #pr-playhead {
    position: absolute; top: 0; width: 2px; background: var(--playhead);
    pointer-events: none; z-index: 20; left: 0;
  }

  /* bottom piano-roll panel */
  #pr { flex: none; height: 244px; display: flex; flex-direction: column;
        border-top: 2px solid var(--line); background: var(--panel); }
  #pr-head { display: flex; align-items: center; gap: 12px; padding: 6px 12px;
             flex: none; border-bottom: 1px solid var(--line); }
  #pr-head .title { font-weight: 600; }
  #pr-head .hint { color: var(--muted); }
  #pr-body { flex: 1; display: grid; grid-template-columns: 60px 1fr; min-height: 0; }
  #pr-keys { background: var(--panel2); border-right: 1px solid var(--line); }
  #pr-scroll { overflow-x: auto; overflow-y: hidden; position: relative; }
  #pr-canvas { display: block; }
</style>
</head>
<body>
<header>
  <h1>{{ title }}</h1>
  <div class="meta">
    <span>key <b id="m-key">—</b></span>
    <span>tempo <b id="m-tempo">—</b> BPM</span>
    <span>time <b id="m-time">0:00</b> / <span id="m-dur">0:00</span></span>
  </div>
  <div class="spacer"></div>
  <button class="toggle" id="btn-roman" title="Toggle chord labels between absolute names and Roman numerals">Roman</button>
  <button class="play" id="btn-play">▶ Play</button>
  <div class="ctlgroup">speed <select id="speed"></select></div>
  <div class="ctlgroup">zoom <input type="range" id="zoom" min="0" max="1" step="0.001" value="0" /></div>
</header>

<div id="app">
  <div id="labels"></div>
  <div id="scroll"><div id="content"><div id="playhead"></div></div></div>
</div>

<div id="pr">
  <div id="pr-head">
    <span class="title">Piano roll</span>
    <select id="pr-stem"></select>
    <span class="hint" id="pr-hint">— pick a stem, or click a stem lane above</span>
  </div>
  <div id="pr-body">
    <canvas id="pr-keys"></canvas>
    <div id="pr-scroll"><canvas id="pr-canvas"></canvas><div id="pr-playhead"></div></div>
  </div>
</div>

<script>
const DATA = {{ data_json|safe }};
const STEM_COLORS = {
  vocals: "#ff6b9d", piano: "#4cc9f0", guitar: "#f4a261",
  drums: "#ffd166", bass: "#06d6a0", other: "#9b8cff",
};
const H = { chords: 40, lyrics: 34, master: 104, disc: 30, stem: 112 };
const HAS_LYRICS = !!(DATA.lyrics && DATA.lyrics.segments && DATA.lyrics.segments.length);
const ENVW = 16000;  // waveform envelope resolution (matches max canvas width)
const PC_WHITE = new Set([0, 2, 4, 5, 7, 9, 11]);
const NOTE_NAMES = ["C","C#","D","D#","E","F","F#","G","G#","A","A#","B"];

const fmt = t => { t = Math.max(0, t|0); return (t/60|0) + ":" + String(t%60).padStart(2,"0"); };

// ---- audio engine: native pitch-preserving playback via <audio> elements.
// Stems play together (they sum to the mix), giving solo/mute; setting
// playbackRate with preservesPitch=true time-stretches without changing pitch.
const Engine = {
  ctx: null, els: {}, clock: null, envs: {}, envMaster: null,
  playing: false, rate: 1, soloed: new Set(), muted: new Set(),
  // Fast: create streaming <audio> elements so playback is ready immediately.
  initPlayback() {
    this.ctx = new (window.AudioContext || window.webkitAudioContext)();
    const names = Object.keys(DATA.stems);
    for (const n of names) {
      const el = new Audio(DATA.stems[n].audio);
      el.preload = "auto"; el.crossOrigin = "anonymous";
      el.preservesPitch = true; el.mozPreservesPitch = true; el.webkitPreservesPitch = true;
      this.els[n] = el;
    }
    this.clock = this.els[names[0]];
  },
  // Slow: decode each WAV to a compact min/max envelope for waveform drawing,
  // calling onReady(name) as each finishes so its lane can redraw progressively.
  async decodeWaveforms(onReady) {
    const jobs = Object.keys(DATA.stems).map(async n => {
      const buf = await this._decode(DATA.stems[n].audio);
      if (buf) { this.envs[n] = peaks(buf.getChannelData(0), ENVW); onReady(n); }
    });
    jobs.push((async () => {
      const buf = await this._decode(DATA.audio);
      if (buf) { this.envMaster = peaks(buf.getChannelData(0), ENVW); onReady("__master"); }
    })());
    await Promise.all(jobs);
  },
  async _decode(url) {
    try { return await this.ctx.decodeAudioData(await (await fetch(url)).arrayBuffer()); }
    catch (e) { console.warn("decode failed", url, e); return null; }
  },
  _applyMute() {
    for (const n in this.els) {
      const audible = (this.soloed.size ? this.soloed.has(n) : true) && !this.muted.has(n);
      this.els[n].muted = !audible;
    }
  },
  now() { return this.clock ? this.clock.currentTime : 0; },
  play(off) {
    if (off == null) off = this.now();
    this._applyMute();
    for (const n in this.els) {
      const el = this.els[n];
      el.playbackRate = this.rate; el.preservesPitch = true;
      el.currentTime = off; el.play().catch(() => {});
    }
    this.playing = true;
  },
  pause() { for (const n in this.els) this.els[n].pause(); this.playing = false; },
  seek(t) {
    t = Math.max(0, Math.min(t, DATA.duration));
    for (const n in this.els) this.els[n].currentTime = t;
  },
  setRate(r) {
    this.rate = r;
    for (const n in this.els) { this.els[n].playbackRate = r; this.els[n].preservesPitch = true; }
  },
  correctDrift() {
    if (!this.playing || !this.clock) return;
    const ref = this.clock.currentTime;
    for (const n in this.els) {
      const el = this.els[n];
      if (el !== this.clock && Math.abs(el.currentTime - ref) > 0.06) el.currentTime = ref;
    }
  },
  toggleMute(n){ this.muted.has(n)?this.muted.delete(n):this.muted.add(n); this._applyMute(); },
  toggleSolo(n){ this.soloed.has(n)?this.soloed.delete(n):this.soloed.add(n); this._applyMute(); },
};

// ---- view state ----
let PPS = 0, FIT = 0, MAXPPS = 0, chordMode = "label", selStem = null, syncing = false;
const scrollEl = document.getElementById("scroll");
const contentEl = document.getElementById("content");
const labelsEl = document.getElementById("labels");
const playheadEl = document.getElementById("playhead");
const prScroll = document.getElementById("pr-scroll");
const prCanvas = document.getElementById("pr-canvas");
const prKeys = document.getElementById("pr-keys");
const prPlayhead = document.getElementById("pr-playhead");
const lanes = [], stemRows = [];
let lyricWords = [], activeWord = null;  // {el, start, end} for karaoke highlight

function peaks(channel, width) {
  const block = channel.length / width, out = new Float32Array(width * 2);
  for (let x = 0; x < width; x++) {
    const s = (x * block) | 0, e = Math.min(channel.length, ((x + 1) * block) | 0);
    let mn = 1, mx = -1;
    for (let i = s; i < e; i++) { const v = channel[i]; if (v < mn) mn = v; if (v > mx) mx = v; }
    if (e <= s) { mn = 0; mx = 0; }
    out[x*2] = mn; out[x*2+1] = mx;
  }
  return out;
}

const COL = { beat: "#3a414f", downbeat: "#5c6479" };
function drawGrid(ctx, h) {
  ctx.strokeStyle = COL.beat; ctx.beginPath();
  for (const t of DATA.beats) { const x = Math.round(t*PPS)+0.5; ctx.moveTo(x,0); ctx.lineTo(x,h); }
  ctx.stroke();
  ctx.strokeStyle = COL.downbeat; ctx.lineWidth = 1.5; ctx.beginPath();
  for (const t of DATA.downbeats) { const x = Math.round(t*PPS)+0.5; ctx.moveTo(x,0); ctx.lineTo(x,h); }
  ctx.stroke(); ctx.lineWidth = 1;
}
function paintWave(ctx, w, h, env, color, alpha) {
  if (!env) return;            // waveform not decoded yet -> grid only
  const mid = h/2, ratio = ENVW / w;
  ctx.fillStyle = color; ctx.globalAlpha = alpha;
  for (let x = 0; x < w; x++) {
    const s = (x*ratio)|0, e = Math.max(s+1, ((x+1)*ratio)|0);
    let mn = 1, mx = -1;
    for (let i = s; i < e; i++) { if (env[i*2] < mn) mn = env[i*2]; if (env[i*2+1] > mx) mx = env[i*2+1]; }
    const y1 = mid - mx*mid*0.95, y2 = mid - mn*mid*0.95;
    ctx.fillRect(x, y1, 1, Math.max(1, y2 - y1));
  }
  ctx.globalAlpha = 1;
}
function noteRange(notes) {
  let lo = 127, hi = 0;
  for (const n of notes) { if (n.pitch < lo) lo = n.pitch; if (n.pitch > hi) hi = n.pitch; }
  if (lo > hi) { lo = 48; hi = 72; }
  return [lo - 1, hi + 1];
}
function paintRoll(ctx, w, h, notes, color, lo, hi) {
  if (!notes || !notes.length) return;
  const span = Math.max(1, hi - lo), nh = Math.max(3, Math.min(12, h/span));
  for (const n of notes) {
    const x = n.s*PPS, ww = Math.max(2, (n.e - n.s)*PPS);
    const y = h - ((n.pitch - lo)/span)*(h - nh) - nh;
    ctx.fillStyle = color; ctx.globalAlpha = 0.45 + 0.55*(n.vel/127);
    ctx.fillRect(x, y, ww, nh);
  }
  ctx.globalAlpha = 1;
}
function drawMaster(c) {
  const ctx = c.getContext("2d"); ctx.clearRect(0,0,c.width,c.height);
  drawGrid(ctx, c.height); paintWave(ctx, c.width, c.height, Engine.envMaster, "#5b9dff", 0.95);
}
function drawStem(c, name, color) {
  const ctx = c.getContext("2d"); ctx.clearRect(0,0,c.width,c.height);
  drawGrid(ctx, c.height);
  paintWave(ctx, c.width, c.height, Engine.envs[name], color, 0.22);
  const notes = DATA.stems[name].notes;
  if (notes && notes.length) { const [lo,hi] = noteRange(notes); paintRoll(ctx, c.width, c.height, notes, color, lo, hi); }
}

function buildLanes() {
  labelsEl.innerHTML = "";
  contentEl.querySelectorAll(".lane, #chordlane").forEach(el => el.remove());
  lanes.length = 0; stemRows.length = 0;

  const addLabel = (h, html, cls) => {
    const d = document.createElement("div");
    d.className = "lane-label" + (cls ? " " + cls : "");
    d.style.height = h + "px"; d.innerHTML = html; labelsEl.appendChild(d); return d;
  };
  const addLane = (h, cls, draw, name) => {
    const lane = document.createElement("div");
    lane.className = "lane" + (cls ? " " + cls : ""); lane.style.height = h + "px";
    if (draw) { const c = document.createElement("canvas"); c.height = h; lane.appendChild(c);
      contentEl.appendChild(lane); lanes.push({ canvas: c, draw, name }); }
    else contentEl.appendChild(lane);
    return lane;
  };

  addLabel(H.chords, `<span>chords</span>`).style.cursor = "default";
  addLane(H.chords, null, null).id = "chordlane";

  if (HAS_LYRICS) {
    addLabel(H.lyrics, `<span>lyrics</span>`).style.cursor = "default";
    addLane(H.lyrics, null, null).id = "lyriclane";
  }

  const mixLabel = addLabel(H.master, `<span class="dot" style="background:var(--master)"></span><span class="name">mix</span>`);
  mixLabel.style.cursor = "default";
  addLane(H.master, null, drawMaster, "__master");

  const stemNames = Object.keys(DATA.stems);
  const discLabel = addLabel(H.disc, `<span class="arrow">▸</span><span>stems (${stemNames.length})</span>`, "disc");
  const discLane = addLane(H.disc, "disc-lane", null);
  let open = false;
  const toggle = () => {
    open = !open; discLabel.classList.toggle("open", open);
    for (const r of stemRows) { r.label.classList.toggle("hidden", !open); r.lane.classList.toggle("hidden", !open); }
    layout();
  };
  discLabel.onclick = toggle;
  discLane.onclick = (e) => { e.stopPropagation(); toggle(); };

  for (const name of stemNames) {
    const color = STEM_COLORS[name] || "#9aa3b2";
    const hasNotes = DATA.stems[name].notes && DATA.stems[name].notes.length;
    const label = addLabel(H.stem, `
      <span class="dot" style="background:${color}"></span><span class="name">${name}</span>
      <span class="ctl">
        <button class="mini solo" data-solo="${name}">S</button>
        <button class="mini mute" data-mute="${name}">M</button>
      </span>`, "hidden" + (hasNotes ? " selectable" : ""));
    const lane = addLane(H.stem, "hidden", (c) => drawStem(c, name, color), name);
    lane.dataset.stem = name;
    if (hasNotes) {
      label.onclick = () => selectStem(name);
      label.querySelector(".name").style.cursor = "pointer";
    }
    stemRows.push({ label, lane, name });
  }

  labelsEl.querySelectorAll("[data-mute]").forEach(b => b.onclick = (e) => {
    e.stopPropagation(); Engine.toggleMute(b.dataset.mute); b.classList.toggle("on");
  });
  labelsEl.querySelectorAll("[data-solo]").forEach(b => b.onclick = (e) => {
    e.stopPropagation(); Engine.toggleSolo(b.dataset.solo); b.classList.toggle("on");
  });
}

function buildChords() {
  const lane = document.getElementById("chordlane"); lane.innerHTML = "";
  for (const c of DATA.chords) {
    const el = document.createElement("div");
    const nc = (c.label === "N" || c.label === "NC");
    el.className = "chord" + (nc ? " nc" : "");
    el.style.left = (c.start*PPS) + "px";
    el.style.width = Math.max(1, (c.end - c.start)*PPS) + "px";
    el.textContent = nc ? "" : (chordMode === "roman" ? (c.roman || c.label) : c.label);
    el.title = `${c.label}${c.roman ? "  ·  " + c.roman : ""}   ${fmt(c.start)}–${fmt(c.end)}`;
    lane.appendChild(el);
  }
}

function buildLyrics() {
  const lane = document.getElementById("lyriclane");
  if (!lane) return;
  lane.innerHTML = ""; lyricWords = []; activeWord = null;
  // Each segment is a readable line block positioned at its start time;
  // consecutive lines alternate between two rows to avoid overlap. Words are
  // inline spans so the active one can be highlighted karaoke-style.
  DATA.lyrics.segments.forEach((seg, i) => {
    const words = (seg.words && seg.words.length)
      ? seg.words
      : [{ start: seg.start, end: seg.end, word: seg.text }];
    const line = document.createElement("div");
    line.className = "lyric-line " + (i % 2 ? "row1" : "row0");
    line.style.left = (seg.start * PPS) + "px";
    line.title = seg.text;
    for (const w of words) {
      const el = document.createElement("span");
      el.className = "lyric-word";
      el.textContent = w.word;
      line.appendChild(el);
      lyricWords.push({ el, start: w.start, end: w.end });
    }
    lane.appendChild(line);
  });
}

// karaoke highlight: mark the word at time t active, earlier words "sung"
function highlightLyrics(t) {
  if (!lyricWords.length) return;
  let cur = null;
  for (const lw of lyricWords) {
    if (t >= lw.start && t < lw.end) { cur = lw; break; }
  }
  if (cur && cur.el === activeWord) return;   // same word still active
  if (!cur && !activeWord) return;            // still in an instrumental gap
  if (activeWord) activeWord.classList.remove("active");
  for (const lw of lyricWords) lw.el.classList.toggle("sung", lw.end <= t);
  activeWord = cur ? cur.el : null;
  if (activeWord) {
    activeWord.classList.remove("sung");
    activeWord.classList.add("active");
  }
}

// ---- detailed bottom piano roll for the selected stem ----
function selectStem(name) {
  selStem = name;
  document.getElementById("pr-stem").value = name;
  document.getElementById("pr-hint").textContent = "";
  for (const r of stemRows) r.label.classList.toggle("selected", r.name === name);
  drawPianoRoll();
}
function drawPianoRoll() {
  const h = prScroll.clientHeight, w = Math.round(DATA.duration * PPS);
  prCanvas.width = w; prCanvas.style.width = w + "px"; prCanvas.height = h;
  prKeys.width = 60; prKeys.height = h;
  prPlayhead.style.height = h + "px";
  const kctx = prKeys.getContext("2d"), pctx = prCanvas.getContext("2d");
  kctx.clearRect(0,0,60,h); pctx.clearRect(0,0,w,h);
  if (!selStem) return;
  const notes = DATA.stems[selStem].notes || [];
  const color = STEM_COLORS[selStem] || "#9aa3b2";
  const [lo, hi] = noteRange(notes), span = Math.max(1, hi - lo), rowH = h / span;

  // keyboard gutter + horizontal pitch lanes
  for (let p = lo; p <= hi; p++) {
    const y = h - (p - lo + 1) * rowH, white = PC_WHITE.has(p % 12);
    kctx.fillStyle = white ? "#2a2f3a" : "#1a1d24";
    kctx.fillRect(0, y, 60, rowH);
    kctx.strokeStyle = "#11131a"; kctx.strokeRect(0, y, 60, rowH);
    if (p % 12 === 0) {
      kctx.fillStyle = "#aeb6c6"; kctx.font = "10px system-ui";
      kctx.fillText("C" + (Math.floor(p/12) - 1), 6, y + rowH - 3);
    }
    pctx.fillStyle = white ? "rgba(255,255,255,0.015)" : "rgba(0,0,0,0.18)";
    pctx.fillRect(0, y, w, rowH);
    if (p % 12 === 0) { pctx.strokeStyle = "#262b35"; pctx.beginPath(); pctx.moveTo(0,y+rowH+0.5); pctx.lineTo(w,y+rowH+0.5); pctx.stroke(); }
  }
  drawGrid(pctx, h);
  // notes (bigger, with outline)
  for (const n of notes) {
    const x = n.s*PPS, ww = Math.max(2, (n.e - n.s)*PPS);
    const y = h - (n.pitch - lo + 1) * rowH;
    pctx.fillStyle = color; pctx.globalAlpha = 0.55 + 0.45*(n.vel/127);
    pctx.fillRect(x, y + 0.5, ww, Math.max(2, rowH - 1));
    pctx.globalAlpha = 1; pctx.strokeStyle = "rgba(0,0,0,0.5)";
    pctx.strokeRect(x + 0.5, y + 0.5, ww, Math.max(2, rowH - 1));
  }
}

function layout() {
  const width = Math.round(DATA.duration * PPS);
  contentEl.style.width = width + "px";
  for (const l of lanes) {
    if (l.canvas.closest(".lane").classList.contains("hidden")) continue;
    l.canvas.width = width; l.canvas.style.width = width + "px"; l.draw(l.canvas);
  }
  buildChords();
  if (HAS_LYRICS) buildLyrics();
  playheadEl.style.height = contentEl.scrollHeight + "px";
  drawPianoRoll();
}

// redraw a single lane (used when its waveform envelope finishes decoding)
function redrawByName(name) {
  const width = Math.round(DATA.duration * PPS);
  for (const l of lanes) {
    if (l.name !== name) continue;
    if (l.canvas.closest(".lane").classList.contains("hidden")) continue;
    l.canvas.width = width; l.canvas.style.width = width + "px"; l.draw(l.canvas);
  }
}

function tick() {
  Engine.correctDrift();
  const t = Engine.now();
  if (Engine.playing && t >= DATA.duration) { Engine.pause(); setPlayBtn(false); }
  const x = t * PPS;
  playheadEl.style.left = x + "px";
  prPlayhead.style.left = x + "px";
  document.getElementById("m-time").textContent = fmt(t);
  if (HAS_LYRICS) highlightLyrics(t);
  if (Engine.playing) {
    const left = scrollEl.scrollLeft, right = left + scrollEl.clientWidth;
    if (x < left + 40 || x > right - 80) scrollEl.scrollLeft = x - scrollEl.clientWidth*0.4;
  }
  requestAnimationFrame(tick);
}
function setPlayBtn(p) { document.getElementById("btn-play").textContent = p ? "⏸ Pause" : "▶ Play"; }

function setupZoom() {
  FIT = (scrollEl.clientWidth - 4) / DATA.duration;
  MAXPPS = Math.max(FIT * 1.2, 16000 / DATA.duration);
  PPS = FIT + (MAXPPS - FIT) * parseFloat(document.getElementById("zoom").value);
}
function setupSpeed() {
  const sel = document.getElementById("speed");
  for (let p = 100; p >= 25; p -= 5) { const o = document.createElement("option");
    o.value = (p/100).toString(); o.textContent = p + "%"; sel.appendChild(o); }
  sel.value = "1"; sel.onchange = () => Engine.setRate(parseFloat(sel.value));
}
function setupStemPicker() {
  const sel = document.getElementById("pr-stem");
  const withNotes = Object.keys(DATA.stems).filter(n => DATA.stems[n].notes && DATA.stems[n].notes.length);
  for (const n of withNotes) { const o = document.createElement("option"); o.value = n;
    o.textContent = n.charAt(0).toUpperCase() + n.slice(1); sel.appendChild(o); }
  sel.onchange = () => selectStem(sel.value);
  return withNotes;
}

async function main() {
  document.getElementById("m-key").textContent = DATA.key ? DATA.key.name : "—";
  document.getElementById("m-tempo").textContent = DATA.tempo || "—";
  document.getElementById("m-dur").textContent = fmt(DATA.duration);

  setupSpeed();
  const withNotes = setupStemPicker();
  Engine.initPlayback();          // fast: playback ready immediately
  buildLanes();
  setupZoom();
  layout();                       // draws grid, chords, MIDI right away
  if (withNotes.length) selectStem(withNotes[0]);
  // decode waveforms in the background; fill in each lane as it's ready
  Engine.decodeWaveforms((name) => redrawByName(name)).then(() => { window.READY = true; });

  document.getElementById("btn-play").onclick = () => {
    if (Engine.playing) { Engine.pause(); setPlayBtn(false); } else { Engine.play(); setPlayBtn(true); }
  };
  document.getElementById("btn-roman").onclick = (e) => {
    chordMode = chordMode === "roman" ? "label" : "roman";
    e.currentTarget.classList.toggle("on", chordMode === "roman");
    buildChords();
  };
  document.getElementById("zoom").oninput = () => { setupZoom(); layout(); };
  scrollEl.addEventListener("scroll", () => {
    labelsEl.scrollTop = scrollEl.scrollTop;
    if (!syncing) { syncing = true; prScroll.scrollLeft = scrollEl.scrollLeft; syncing = false; }
  });
  prScroll.addEventListener("scroll", () => {
    if (!syncing) { syncing = true; scrollEl.scrollLeft = prScroll.scrollLeft; syncing = false; }
  });
  contentEl.onclick = (e) => {
    const rect = contentEl.getBoundingClientRect();
    Engine.seek((e.clientX - rect.left) / PPS);
    const lane = e.target.closest(".lane[data-stem]");
    if (lane && DATA.stems[lane.dataset.stem].notes?.length) selectStem(lane.dataset.stem);
    if (!Engine.playing) tickOnce();
  };
  window.addEventListener("resize", () => { setupZoom(); layout(); });
  tick();
}
function tickOnce() {
  const x = Engine.now() * PPS;
  playheadEl.style.left = x + "px"; prPlayhead.style.left = x + "px";
  document.getElementById("m-time").textContent = fmt(Engine.now());
}
main();
</script>
</body>
</html>
